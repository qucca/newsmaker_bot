# Скопируй в .env и заполни значения. Файл .env НЕ коммитим.
# Дополнительные переменные будут добавляться по мере задач (валидация — в T2, src/config).

# Telegram bot token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Выбор LLM-провайдера: anthropic | openai | google
LLM_PROVIDER=anthropic

# Ключ нужен только у ВЫБРАННОГО провайдера
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Модели по ролям. Для anthropic дефолты зашиты (claude-haiku-4-5 / claude-sonnet-4-6);
# для openai/google LLM_MODEL_DEFAULT обязателен. LLM_MODEL_RENDER не задан → = default.
LLM_MODEL_DEFAULT=
LLM_MODEL_RENDER=

# Путь к файлу базы данных SQLite
DATABASE_PATH=./data/news_bot.sqlite

# Обогащение (T7): размер батча на один LLM-вызов и кап кандидатов за прогон
MAX_ENRICH_BATCH=20
ENRICH_RUN_CAP=200
