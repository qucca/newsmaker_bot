# Скопируй в .env и заполни значения. Файл .env НЕ коммитим.
# Дополнительные переменные будут добавляться по мере задач (валидация — в T2, src/config).

# Telegram bot token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Выбор LLM-провайдера: anthropic | openai | google
LLM_PROVIDER=anthropic

# Ключ нужен только у ВЫБРАННОГО провайдера
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Модели по ролям. Для anthropic дефолты зашиты (claude-haiku-4-5 / claude-sonnet-4-6);
# для openai/google LLM_MODEL_DEFAULT обязателен. LLM_MODEL_RENDER не задан → = default.
LLM_MODEL_DEFAULT=
LLM_MODEL_RENDER=

# Путь к файлу базы данных SQLite
DATABASE_PATH=./data/news_bot.sqlite

# Обогащение (T7): размер батча на один LLM-вызов и кап кандидатов за прогон
MAX_ENRICH_BATCH=20
ENRICH_RUN_CAP=200

# Кластеризация (T8): окно матчинга в часах (по first_seen) и кап статей за прогон
CLUSTER_WINDOW_HOURS=72
CLUSTER_RUN_CAP=500

# Онбординг (T9): максимум активных пользователей (предохранитель публичной регистрации)
MAX_USERS=100

# Ранжирование (T10): окно свежести кандидатов-кластеров в часах (по updated_at)
SCORE_WINDOW_HOURS=72

# Ретенция БД: горизонт хранения articles/clusters в днях (daily-тик чистки). ОБЯЗАН быть
# >= окон кластеризации/ранжирования (72ч) — иначе всплывёт переотправка. Дефолт 14д >> 72ч.
RETENTION_DAYS=14

# Отправка (T13): лимиты троттла очереди — сообщений/сек глобально и на один чат
SEND_GLOBAL_RPS=30
SEND_PER_CHAT_RPS=1

# Планировщик (T15): интервал тикера окон чтения и интервал глобального прохода (минуты)
TICK_INTERVAL_MIN=15
GLOBAL_PASS_INTERVAL_MIN=30

# Калибровка (T14): кнопки 👍/👎 на первых N карточках юзера (0 — выключить кнопки)
CALIBRATION_CARDS=30

# Рендер (T11): потолок выходных токенов на одно саммари
RENDER_MAX_OUTPUT_TOKENS=800

# Google News (T16): kill-switch L2 (true|false). По умолчанию выключен — L1 самодостаточен;
# раскрутка завёрнутых URL GN — самая хрупкая зависимость, включаем осознанно.
GOOGLE_NEWS_ENABLED=false
