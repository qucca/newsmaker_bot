{
  "name": "news-bot",
  "version": "0.1.0",
  "description": "Многопользовательский Telegram-бот — персональный новостной куратор",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migrate": "tsx src/db/migrate.ts",
    "seed:sources": "tsx src/sources/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/genai": "^2.9.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "better-sqlite3": "^12.11.1",
    "grammy": "^1.44.0",
    "luxon": "^3.7.2",
    "openai": "^6.44.0",
    "rss-parser": "^3.13.0",
    "zod": "^4.4.3"
  }
}
